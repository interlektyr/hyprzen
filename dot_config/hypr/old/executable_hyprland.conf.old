# This is an example Hyprland config file.
# Refer to the wiki for more information.
# https://wiki.hypr.land/Configuring/

# Please note not all available settings / options are set here.
# For a full list, see the wiki

# You can split this configuration into multiple files
# Create your files separately and then link them to this file like this:
# source = ~/.config/hypr/myColors.conf


################
### MONITORS ###
################

exec-once = ~/.config/hypr/hyp_mon.sh

# See https://wiki.hypr.land/Configuring/Monitors/
#monitor=,preferred,auto,1.33


###################
### MY PROGRAMS ###
###################

# See https://wiki.hypr.land/Configuring/Keywords/

# Set programs that you use
$terminal = kitty
$fileManager = thunar
$menu = rofi 


#################
### AUTOSTART ###
#################

# Autostart necessary processes (like notifications daemons, status bars, etc.)
# Or execute your favorite apps at launch like this:

# exec-once = quickshell -p ~/.config/quickshell/WIMLockScreen.qml
exec-once = udisks2 &
exec-once = udiskie &
exec-once = awww-daemon &
exec-once = [workspace special:terminal silent] kitty --title dropdterm -e fish
exec-once = [workspace special:zbrowser silent] zen-browser --start-fullscreen
exec-once = quickshell &
#exec-once = hyprlock
#exec-once = quickshell -p ~/.config/quickshell/WIMLockScreen.qml 


#############################
### ENVIRONMENT VARIABLES ###
#############################

# See https://wiki.hypr.land/Configuring/Environment-variables/

env = XCURSOR_SIZE,24
env = HYPRCURSOR_THEME,rose-pine-hyprcursor
env = HYPRCURSOR_SIZE,24
env = LIBVA_DRIVER_NAME,nvidia
env = __GLX_VENDOR_LIBRARY_NAME,nvidia
env = AWWW_TRANSITION_DURATION,0.8
env = AWWW_TRANSITION_WAVE,0,0
env = QT_AUTO_SCREEN_SCALE_FACTOR,1
env = QT_QPA_PLATFORM,wayland;xcb
env = GDK_SCALE,1.33


###################
### PERMISSIONS ###
###################

# See https://wiki.hypr.land/Configuring/Permissions/
# Please note permission changes here require a Hyprland restart and are not applied on-the-fly
# for security reasons

# ecosystem {
#   enforce_permissions = 1
# }

# permission = /usr/(bin|local/bin)/grim, screencopy, allow
# permission = /usr/(lib|libexec|lib64)/xdg-desktop-portal-hyprland, screencopy, allow
# permission = /usr/(bin|local/bin)/hyprpm, plugin, allow


#####################
### LOOK AND FEEL ###
#####################

# Refer to https://wiki.hypr.land/Configuring/Variables/

# https://wiki.hypr.land/Configuring/Variables/#general
general {
    gaps_in = 5
    gaps_out = 20

    border_size = 0

    # https://wiki.hypr.land/Configuring/Variables/#variable-types for info about colors
    col.active_border = rgba(245,208,152,1)
    col.inactive_border = rgba(595959aa)

    # Set to true enable resizing windows by clicking and dragging on borders and gaps
    resize_on_border = false

    # Please see https://wiki.hypr.land/Configuring/Tearing/ before you turn this on
    allow_tearing = false

    layout = dwindle
}

# https://wiki.hypr.land/Configuring/Variables/#decoration
decoration {
    dim_inactive = false 
    dim_strength = 0.03
    rounding = 10 
    rounding_power = 2
    dim_around = 0.2  

    # Change transparency of focused and unfocused windows
    active_opacity = 1.0
    inactive_opacity = 1.0

    shadow {
        enabled = true
        range = 4
        render_power = 3
        color = rgba(1a1a1aee)
    }

    # https://wiki.hypr.land/Configuring/Variables/#blur
    blur {
        enabled = true
        size = 3
        passes = 1

        vibrancy = 0.1696
    }
}

# https://wiki.hypr.land/Configuring/Variables/#animations
animations {
    enabled = yes, please :)

    # Default curves, see https://wiki.hypr.land/Configuring/Animations/#curves
    #        NAME,           X0,   Y0,   X1,   Y1
    bezier = easeOutQuint,   0.23, 1,    0.32, 1
    bezier = easeInOutCubic, 0.65, 0.05, 0.36, 1
    bezier = linear,         0,    0,    1,    1
    bezier = almostLinear,   0.5,  0.5,  0.75, 1
    bezier = quick,          0.15, 0,    0.1,  1
    bezier = backOut,        0.34, 1.56, 0.64, 1

    # Default animations, see https://wiki.hypr.land/Configuring/Animations/
    #           NAME,          ONOFF, SPEED, CURVE,        [STYLE]
    animation = global,        1,     10,    default
    animation = border,        1,     5.39,  easeOutQuint
    animation = windows,       1,     4.79,  easeOutQuint
    animation = windowsIn,     1,     3,     backOut,      popin 80%
    animation = windowsOut,    1,     1.49,  linear,       popin 87%
    animation = fadeIn,        1,     1.73,  almostLinear
    animation = fadeOut,       1,     1.46,  almostLinear
    animation = fade,          1,     3.03,  quick
    animation = layers,        1,     3.81,  easeOutQuint
    animation = layersIn,      1,     3,     linear,       fade
    animation = layersOut,     1,     1.5,   linear,       fade
    animation = fadeLayersIn,  1,     1.79,  almostLinear
    animation = fadeLayersOut, 1,     1.39,  almostLinear
    animation = workspaces,    1,     1.94,  almostLinear, fade
    animation = workspacesIn,  1,     2.5,   almostLinear, slide
    animation = workspacesOut, 1,     2.5,   almostLinear, slide
    animation = zoomFactor,    1,     7,     quick
    animation = specialWorkspaceIn, 1, 2.5,  almostLinear, slide top
    animation = specialWorkspaceOut, 1, 2.5, almostLinear, slide bottom 
}

# Ref https://wiki.hypr.land/Configuring/Workspace-Rules/
# "Smart gaps" / "No gaps when only"
# uncomment all if you wish to use that.
# workspace = w[tv1], gapsout:0, gapsin:0
# workspace = f[1], gapsout:0, gapsin:0
# windowrule {
#     name = no-gaps-wtv1
#     match:float = false
#     match:workspace = w[tv1]
#
#     border_size = 0
#     rounding = 0
# }
#
# windowrule {
#     name = no-gaps-f1
#     match:float = false
#     match:workspace = f[1]
#
#     border_size = 0
#     rounding = 0
# }

windowrule {
  name = floating
  match:workspace = r[1-10]s[false]
  float = true
  fullscreen = false
#  size = 1500 1000
}

windowrule {
  name = handle-yazi
  match:class = kitty
  match:title = yazi
  float = true
  size = 1500 1000
}

windowrule {
  name = handle-moonbit
  match:class = kitty
  match:title = moonbit 
  float = true
  size = 797 593
}


windowrule {
  name = handle-zen
  match:class = zen
  float = false
#  size = 1500 1000
}

windowrule {
  name = handle-dropdownterminal
  match:class = kitty
  match:title = dropdterm
  float = false
#  size = 1500 1000
}

windowrule {
  name = handle-appcommander
  match:class = kitty
  match:title = appcom
  float = true 
  size = 1388 714
  border_size = 3  
  border_color = rgba(245,208,152,1)
}

windowrule {
  name = handle-power_m
  match:class = kitty
  match:title = pmenu
  float = true 
  size = 764 273
}

windowrule {
  name = handle-connection_m
  match:class = kitty
  match:title = cmenu
  float = true 
  size = 764 293
}

windowrule {
  name = handle-system_m
  match:class = kitty
  match:title = smenu
  float = true 
  size = 764 267
}

windowrule {
  name = handle-confirm
  match:class = kitty
  match:title = gum_con
  float = true 
  size = 380 132
}

windowrule {
  name = handle-stasher
  match:class = kitty
  match:title = stash
  float = true 
  size = 1388 714
  border_size = 3
  border_color = rgba(202,140,112,1)
}

#windowrule {
#    name = handle-wswidget
#    match:namespace = workspace-hud
#    no_anim = true
#  }


# See https://wiki.hypr.land/Configuring/Dwindle-Layout/ for more
dwindle {
#    pseudotile = true # Master switch for pseudotiling. Enabling is bound to mainMod + P in the keybinds section below
    preserve_split = true # You probably want this
}

# See https://wiki.hypr.land/Configuring/Master-Layout/ for more
master {
    new_status = master
}

# https://wiki.hypr.land/Configuring/Variables/#misc
misc {
    force_default_wallpaper = 0 # Set to 0 or 1 to disable the anime mascot wallpapers
    disable_hyprland_logo = true # If true disables the random hyprland logo / anime girl background. :(
}

xwayland {
    force_zero_scaling = true
  }

#############
### INPUT ###
#############

# https://wiki.hypr.land/Configuring/Variables/#input
input {
    kb_layout = se
    kb_variant =
    kb_model =
    kb_options =
    kb_rules =

    follow_mouse = 1

    sensitivity = 0 # -1.0 - 1.0, 0 means no modification.

    touchpad {
        natural_scroll = false
    }
}

# See https://wiki.hypr.land/Configuring/Gestures
gesture = 3, horizontal, workspace

# Example per-device config
# See https://wiki.hypr.land/Configuring/Keywords/#per-device-input-configs for more
device {
    name = epic-mouse-v1
    sensitivity = -0.5
}


###################
### KEYBINDINGS ###
###################

$wsctl = ~/.config/hypr/hyp_win.sh
$bat = ~/.config/hypr/hyp_bat.sh
$date = ~/.config/hypr/hyp_clock.sh
$vol = ~/.config/hypr/hyp_vol.sh
$power = ~/.config/hypr/hyp_m_power.sh
$system = ~/.config/hypr/hyp_m_system.sh 

# See https://wiki.hypr.land/Configuring/Keywords/
$mainMod = SUPER # Sets "Windows" key as main modifier

# Example binds, see https://wiki.hypr.land/Configuring/Binds/ for more
bind = $mainMod, K, exec, $terminal --title yazi -e fish
bind = $mainMod, C, killactive,
bind = $mainMod CTRL, up, fullscreen
bind = $mainMod, M, exec, command -v hyprshutdown >/dev/null 2>&1 && hyprshutdown || hyprctl dispatch exit
bind = $mainMod CTRL, SPACE, exec, $terminal --title yazi -e yazi
bind = $mainMod, V, togglefloating,
#bind = $mainMod, SPACE, exec, [workspace special:stash silent no_anim 1] $terminal --title appcom -e ~/.config/hypr/hyp_appcommander.sh >/dev/null 2>&1 & exit 
bind = $mainMod, SPACE, global, quickshell:appcommander_hud
#bind = $mainMod, P, pseudo, # dwindle
bind = $mainMod, J, layoutmsg, togglesplit # dwindle
bind = $mainMod CTRL, D, exec, $wsctl show 
bind = $mainMod, Z, exec, zen-browser
bind = $mainMod, F, exec, firefox
bind = $mainMod, N, exec, neovide
#bind = $mainMod, B, exec, $bat
bind = $mainMod, B, global, quickshell:battery_hud
#bind = $mainMod ALT, RETURN, exec, $date
bind = $mainMod ALT, RETURN, global, quickshell:clock_hud 
bind = $mainMod, DELETE, exec, $power -m
bind = $mainMod CTRL, DELETE, global, quickshell:power_hud
bind = $mainMod, I, exec, [workspace special:stash silent no_anim 1] $terminal --title cmenu -e ~/.config/hypr/hyp_conn.sh >/dev/null 2>&1
bind = $mainMod, U, exec, $terminal --title yazi -e arch-update
#bind = $mainMod, S, exec, [workspace special:stash silent no_anim 1] $terminal --title smenu -e ~/.config/hypr/hyp_system.sh >/dev/null 2>&1
#bind = $mainMod, S, exec, $system -m
bind = $mainMod, S, global, quickshell:zensys_hud
bind = $mainMod, P, exec, hyprshot -m output
bind = $mainMod CTRL, P, exec, hyprshot -m region

#test
bind = $mainMod CTRL, L, exec, ~/.config/hypr/hyp_mon.sh
bind = $mainMod, O, global, quickshell:lockTheScreen
bind = $mainMod, W, global, quickshell:workspace_hud
#bind = $mainMod, E, global, quickshell:clock_hud
bind = $mainMod, G, global, quickshell:zensys_hud
#bind = $mainMod CTRL, B, global, quickshell:battery_hud
bind = $mainMod CTRL, V, global, quickshell:volume_hud 

# Move focus with mainMod + arrow keys
bind = $mainMod, left, movefocus, l
bind = $mainMod, left, bringactivetotop,
bind = $mainMod, right, movefocus, r
bind = $mainMod, right, bringactivetotop,
bind = $mainMod, up, movefocus, u
bind = $mainMod, up, bringactivetotop,
bind = $mainMod, down, movefocus, d
bind = $mainMod, down, bringactivetotop,

# Switch workspaces with mainMod + [0-9]
#OLD bind = $mainMod, 2, workspace, 2
# OLD bind = $mainMod, 1, exec, $wsctl jump 1
bind = $mainMod, 1, workspace, 1
bind = $mainMod, 2, workspace, 2
bind = $mainMod, 3, workspace, 3
bind = $mainMod, 4, workspace, 4
bind = $mainMod, 5, workspace, 5
bind = $mainMod, 6, workspace, 6
bind = $mainMod, 7, workspace, 7
bind = $mainMod, 8, workspace, 8
bind = $mainMod, 9, workspace, 9
bind = $mainMod, 0, workspace, 10
#bind = $mainMod CTRL, right, exec, $wsctl f
#bind = $mainMod CTRL, left, exec, $wsctl b

# Test 
# Scroll through existing workspaces with mainMod + scroll
bind = $mainMod CTRL, right, workspace, +1
bind = $mainMod CTRL, left, workspace, -1

# Move active window to a workspace with mainMod + CTRL + [0-9]
# OLD bind = $mainMod CTRL, 1, exec, $wsctl move 1
bind = $mainMod CTRL, 1, movetoworkspace, 1
bind = $mainMod CTRL, 2, movetoworkspace, 2
bind = $mainMod CTRL, 3, movetoworkspace, 3
bind = $mainMod CTRL, 4, movetoworkspace, 4 
bind = $mainMod CTRL, 5, movetoworkspace, 5
bind = $mainMod CTRL, 6, movetoworkspace, 6
bind = $mainMod CTRL, 7, movetoworkspace, 7
bind = $mainMod CTRL, 8, movetoworkspace, 8 
bind = $mainMod CTRL, 9, movetoworkspace, 9
bind = $mainMod CTRL, 0, movetoworkspace, 10

# Example special workspace (scratchpad)
bind = $mainMod, RETURN, togglespecialworkspace, terminal
bind = $mainMod CTRL, RETURN, togglespecialworkspace, zbrowser
bind = $mainMod CTRL, S, movetoworkspace, special:zbrowser
bind = $mainMod, H, exec, [workspace special:stash silent no_anim 1] $terminal --title stash -e ~/.config/hypr/hyp_stash.sh >/dev/null 2>&1 
bind = $mainMod CTRL, down, movetoworkspacesilent, special:stash

# Scroll through existing workspaces with mainMod + scroll
bind = $mainMod, mouse_down, workspace, e+1
bind = $mainMod, mouse_up, workspace, e-1

# Move/resize windows with mainMod + LMB/RMB and dragging
binds {
    drag_threshold = 10  # Fire a drag event only after dragging for more than 10px
}
bindm = $mainMod, mouse:272, movewindow      
bindc = $mainMod, mouse:272, togglefloating  

# bindm = $mainMod, mouse:272, movewindow
bindm = $mainMod, mouse:273, resizewindow
bindc = $mainMod, mouse:273, movetoworkspacesilent, special:stash
bindc = $mainMod CTRL, mouse:273, killactive,

# Laptop multimedia keys for volume and LCD brightness
bindel = ,XF86AudioRaiseVolume, exec, wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+
#bindel = ,XF86AudioRaiseVolume, exec, $vol -u 
bindel = ,XF86AudioLowerVolume, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
#bindel = ,XF86AudioLowerVolume, exec, $vol -d
bindel = ,XF86AudioMute, exec, wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindel = ,XF86AudioRaiseVolume, global, quickshell:volume_hud
bindel = ,XF86AudioLowerVolume, global, quickshell:volume_hud
bindel = ,XF86AudioMute, global, quickshell:volume_hud
#bindel = ,XF86AudioMute, exec, $vol -m
bindel = ,XF86AudioMicMute, exec, wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
bindel = ,XF86MonBrightnessUp, exec, brightnessctl -e4 -n2 set 5%+
bindel = ,XF86MonBrightnessDown, exec, brightnessctl -e4 -n2 set 5%-

# Requires playerctl
bindl = , XF86AudioNext, exec, playerctl next
bindl = , XF86AudioPause, exec, playerctl play-pause
bindl = , XF86AudioPlay, exec, playerctl play-pause
bindl = , XF86AudioPrev, exec, playerctl previous

# Submask `power`.
bind = $mainMod, DELETE, submap, power 
submap = power
bind = , L, exec, $power -l
bind = , E, exec, $power -e
bind = , S, exec, $power -s
bind = , R, exec, $power -r
bind = , F, exec, $power -f
bind = , escape, exec, $power -q
bind = , RETURN, exec, $power -q
bindc = , mouse:272, exec, $power -q
bind = $mainMod, escape, submap, reset
submap = reset

# Submask `system`.
#bind = $mainMod, S, submap, system 
submap = system
bind = , U, exec, $system -u 
bind = , M, exec, $system -mi 
bind = , S, exec, $system -s  
bind = , C, exec, $system -c 
bind = , B, exec, $system -b 
bind = , escape, exec, $system -q
bind = , RETURN, exec, $system -q
bindc = , mouse:272, exec, $system -q
bind = $mainMod, escape, submap, reset
submap = reset

##############################
### WINDOWS AND WORKSPACES ###
##############################

# See https://wiki.hypr.land/Configuring/Window-Rules/ for more
# See https://wiki.hypr.land/Configuring/Workspace-Rules/ for workspace rules

# Example windowrules that are useful

windowrule {
    # Ignore maximize requests from all apps. You'll probably like this.
    name = suppress-maximize-events
    match:class = .*

    suppress_event = maximize
}

windowrule {
    # Fix some dragging issues with XWayland
    name = fix-xwayland-drags
    match:class = ^$
    match:title = ^$
    match:xwayland = true
    match:float = true
    match:fullscreen = false
    match:pin = false

    no_focus = true
}

# Hyprland-run windowrule
windowrule {
    name = move-hyprland-run

    match:class = hyprland-run

    move = 20 monitor_h-120
    float = yes
}
